# =============================================================================
# .env.example — Modèle de configuration
# -----------------------------------------------------------------------------
# COPIEZ ce fichier en « .env » puis adaptez les valeurs :
#
#     cp .env.example .env
#
# Le fichier .env réel N'EST PAS versionné (voir .gitignore) : il contient vos
# secrets. NE COMMITTEZ JAMAIS de vrais mots de passe.
#
# Docker Compose lit automatiquement .env pour substituer les ${VARIABLES}.
# =============================================================================

# --- Docker Compose ----------------------------------------------------------
# Nom de projet (préfixe des conteneurs, réseaux et volumes Docker).
COMPOSE_PROJECT_NAME=bibliotheque

# --- Environnement -----------------------------------------------------------
# "developpement" (messages détaillés, CORS souple) ou "production" (strict).
APP_ENVIRONNEMENT=developpement

# --- Serveur HTTP ------------------------------------------------------------
# Port exposé sur la MACHINE HÔTE (accès à l'API depuis votre navigateur/curl).
SERVEUR_PORT_HOTE=8080
# Délais (format Go : 10s, 15s, 1m...).
SERVEUR_DELAI_LECTURE=10s
SERVEUR_DELAI_ECRITURE=15s
SERVEUR_DELAI_TRAITEMENT=10s
SERVEUR_DELAI_ARRET=15s

# --- Base de données PostgreSQL ----------------------------------------------
# Nom de la base et du rôle applicatif (créés automatiquement à l'initialisation).
BDD_NOM=bibliotheque
BDD_UTILISATEUR=app_bibliotheque
# SECRETS : à remplacer par des valeurs fortes et uniques.
# BDD_MOT_DE_PASSE = mot de passe du RÔLE APPLICATIF (app_bibliotheque).
BDD_MOT_DE_PASSE=changez_moi_mot_de_passe_app
# BDD_ROOT_MOT_DE_PASSE = mot de passe du SUPERUTILISATEUR postgres.
BDD_ROOT_MOT_DE_PASSE=changez_moi_mot_de_passe_root
# Port PostgreSQL exposé sur l'hôte (pour psql / un client SQL externe).
BDD_PORT_HOTE=5432
# Réglages du pool de connexions côté application.
BDD_MAX_CONNEXIONS_OUVERTES=25
BDD_MAX_CONNEXIONS_INACTIVES=25
BDD_DUREE_VIE_CONNEXION=5m

# --- Authentification JWT ----------------------------------------------------
# SECRET de signature HMAC : AU MOINS 32 caractères. Générez-en un aléatoire, ex :
#   openssl rand -base64 48
JWT_SECRET=changez_moi_secret_jwt_de_32_caracteres_minimum_svp
JWT_EMETTEUR=api-bibliotheque
JWT_DUREE_ACCES=15m
JWT_DUREE_RAFRAICHISSEMENT=168h

# --- Sécurité ----------------------------------------------------------------
# Origines CORS autorisées (séparées par des virgules). "*" INTERDIT en production.
CORS_ORIGINES_AUTORISEES=*
# Taille maximale du corps d'une requête, en octets (1 Mio par défaut).
REQUETE_TAILLE_MAX_OCTETS=1048576
# Limitation de débit : requêtes/seconde et pic toléré (burst), par adresse IP.
RATE_LIMIT_PAR_SECONDE=10
RATE_LIMIT_RAFALE=20

# --- Journalisation ----------------------------------------------------------
# Niveau : debug | info | warn | error. Format : json | texte.
LOG_NIVEAU=info
LOG_FORMAT=json
